{
  "global_trackers": ["utm_source", "utm_medium", "utm_campaign", "utm_term", "utm_content", "fbclid", "gclid"],
  "platform_rules": [
    {
      "name": "Instagram",
      "hosts": ["instagram.com", "instagr.am", "threads.net"],
      "packages": ["com.instagram.android"],
      "params": ["igsh", "igshid", "utm_source"]
    },
    {
      "name": "Spotify",
      "hosts": ["spotify.com", "open.spotify.com"],
      "packages": ["com.spotify.music"],
      "params": ["si", "pi", "nd"]
    },
    {
      "name": "TikTok",
      "hosts": ["tiktok.com", "v.tiktok.com"],
      "packages": ["com.zhiliaoapp.musically"],
      "params": ["_r", "is_from_webapp", "sender_device", "share_link_id"]
    },
    {
      "name": "YouTube",
      "hosts": ["youtube.com", "youtu.be", "m.youtube.com"],
      "packages": ["com.google.android.youtube"],
      "params": ["si", "feature"]
    },
    {
      "name": "Twitter / X",
      "hosts": ["twitter.com", "x.com", "t.co"],
      "packages": ["com.twitter.android"],
      "params": ["s", "t"]
    }
  ]
}